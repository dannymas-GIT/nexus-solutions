# Nexus Solutions - Environment Configuration
# Copy to .env and fill in values:  cp .env.example .env

# Database (PostgreSQL - used by Docker Compose)
NEXUS_DB_USER=nexus_user
NEXUS_DB_PASSWORD=nexus_password
NEXUS_DB_NAME=nexus_solutions

# Optional: override backend DATABASE_URL if running outside Docker
# DATABASE_URL=postgresql://nexus_user:nexus_password@localhost:5433/nexus_solutions

# Azure AD / OneDrive (optional - set only if using OneDrive storage)
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# CERT_PATH=/path/to/certificate.pfx
# CERT_PASSWORD=
# STORAGE_PROVIDER=onedrive

# OpenAI (optional - for AI-powered features)
# OPENAI_API_KEY=
